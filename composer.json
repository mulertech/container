{
  "name": "mulertech/container",
  "description": "The MulerTech dependency injection container",
  "type": "library",
  "keywords": [
    "php",
    "dependency-injection",
    "container",
    "psr-11"
  ],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Sébastien Muler",
      "email": "sebastien.muler@mulertech.net"
    }
  ],
  "require": {
    "php": "^8.4",
    "symfony/yaml": "^6||^7",
    "psr/container": "^2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.6",
    "mulertech/docker-dev": "^3.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "MulerTech\\Container\\": "./src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MulerTech\\Container\\Tests\\": "./tests"
    }
  },
  "config": {
    "sort-packages": true
  }
}
